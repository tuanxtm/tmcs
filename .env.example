# =============================================================================
# TMCS environment variables
# Copy to `.env` for local development. Never commit real secrets.
# Documented further in README.md
# =============================================================================

# Required — Payload encryption/signing secret.
# Generate with: openssl rand -hex 32
PAYLOAD_SECRET=

# Public canonical site URL (no trailing slash).
# Used for Admin preview links, SEO URL helpers, and contact source validation.
# Local default: http://localhost:3000
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Extra origins for Payload CSRF cookie auth + CORS (comma-separated, no trailing slash).
# In local `next dev`, Admin login via LAN IP works without this (csrf is disabled in
# development). Set in production when the app is reachable from multiple public origins.
# PAYLOAD_CSRF_ORIGINS=https://www.example.com

# Optional comma-separated hosts/origins allowed by Next.js `allowedDevOrigins`
# when opening `next dev` via a LAN IP or tunnel (not needed for localhost).
# Example: ALLOWED_DEV_ORIGINS=10.199.1.10,http://192.168.1.20:3000
# ALLOWED_DEV_ORIGINS=

# Required in production — shared secret for Cloudflare Cron → /api/cron/jobs.
# Generate with: openssl rand -hex 32
# Set as a Wrangler/Cloudflare Worker secret in production.
CRON_SECRET=

# Required for contact abuse hashing (IP / user-agent hashes, not raw IPs).
# Falls back to PAYLOAD_SECRET if unset. Generate with: openssl rand -hex 32
CONTACT_HASH_SECRET=

# Optional Payload log level in production Workers (trace|debug|info|warn|error)
# PAYLOAD_LOG_LEVEL=info

# Optional Wrangler environment name for deploy/preview (e.g. staging)
# CLOUDFLARE_ENV=

# -----------------------------------------------------------------------------
# Seed script credentials (local/dev only — never use in production)
# Used by: bun run seed
# -----------------------------------------------------------------------------
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NAME=Site Admin

SEED_MANAGER_EMAIL=manager@example.com
SEED_MANAGER_PASSWORD=
SEED_MANAGER_NAME=Site Manager

SEED_CREATOR_EMAIL=creator@example.com
SEED_CREATOR_PASSWORD=
SEED_CREATOR_NAME=Site Creator
